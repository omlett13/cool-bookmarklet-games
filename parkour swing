javascript:(()=>{if(window.swingGame){window.swingGame();return;}const c=document.createElement("canvas");document.body.appendChild(c);c.style.cssText="position:fixed;inset:0;z-index:999999;background:#cfd6dc;cursor:crosshair;";const x=c.getContext("2d");let W=innerWidth,H=innerHeight,DPR=1;function resize(){W=innerWidth;H=innerHeight;DPR=Math.max(1,Math.min(2,devicePixelRatio||1));c.width=W*DPR;c.height=H*DPR;c.style.width=W+"px";c.style.height=H+"px";x.setTransform(DPR,0,0,DPR,0,0);x.imageSmoothingEnabled=true}resize();addEventListener("resize",resize);const keys={};let score=0,best=0,dead=false,deathTimer=0,combo=1,comboTimer=0,trickScore=0,lastHookSpeed=0;const worldW=9000,worldH=3600,groundY=worldH-120,gravity=0.2,air=0.997,sideAccel=0.34;const p={x:500,y:850,vx:0,vy:0,r:11,rot:0};const cam={x:0,y:0};const hook={active:false,x:0,y:0,len:0};const particles=[];const skyline=[];const buildings=[];let bx=220;for(let i=0;i<55;i++){const gap=80+Math.random()*90,bw=150+Math.random()*170,bh=260+Math.random()*980,by=groundY-bh,gx=bx+bw*.5,gy=by-(85+Math.random()*75);buildings.push({x:bx,y:by,w:bw,h:bh,grappleX:gx,grappleY:gy,shade:55+Math.random()*35,winSeed:Math.random()*999});bx+=bw+gap}for(let i=0;i<22;i++){const sw=260+Math.random()*220,sh=120+Math.random()*260,sx=150+i*380;skyline.push({x:sx,y:groundY-sh-600-Math.random()*180,w:sw,h:sh,a:0.07+Math.random()*0.05})}function clamp(v,a,b){return Math.max(a,Math.min(b,v))}function dist(ax,ay,bx,by){return Math.hypot(bx-ax,by-ay)}function lerp(a,b,t){return a+(b-a)*t}function speed(){return Math.hypot(p.vx,p.vy)}function crash(){if(dead)return;dead=true;deathTimer=0;hook.active=false;best=Math.max(best,Math.floor(score));for(let i=0;i<28;i++){const a=Math.random()*Math.PI*2,s=2+Math.random()*7;particles.push({x:p.x,y:p.y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,life:25+Math.random()*25,size:3+Math.random()*5})}}function restart(){dead=false;deathTimer=0;score=0;combo=1;comboTimer=0;trickScore=0;lastHookSpeed=0;p.x=500;p.y=850;p.vx=0;p.vy=0;p.rot=0;hook.active=false;particles.length=0}function tryHook(mx,my){if(dead)return;const wx=cam.x+mx,wy=cam.y+my;let bestPt=null,bestScore=1e9;for(const b of buildings){const dClick=dist(wx,wy,b.grappleX,b.grappleY),dPlayer=dist(p.x,p.y,b.grappleX,b.grappleY);if(dPlayer>760)continue;const s=dClick+dPlayer*.35;if(s<bestScore){bestScore=s;bestPt={x:b.grappleX,y:b.grappleY}}}if(bestPt){lastHookSpeed=speed();hook.active=true;hook.x=bestPt.x;hook.y=bestPt.y;hook.len=dist(p.x,p.y,hook.x,hook.y)}}function releaseHook(){if(hook.active){const gain=Math.max(0,speed()-lastHookSpeed);if(gain>1.2){const add=Math.floor(gain*40*combo);score+=add;trickScore=add;combo=Math.min(8,combo+1);comboTimer=180}hook.active=false}}function updatePhysics(){if(dead){deathTimer++;for(let i=particles.length-1;i>=0;i--){const q=particles[i];q.x+=q.vx;q.y+=q.vy;q.vy+=0.18;q.vx*=0.98;q.life--;if(q.life<=0)particles.splice(i,1)}return}if(keys.a||keys.ArrowLeft)p.vx-=sideAccel;if(keys.d||keys.ArrowRight)p.vx+=sideAccel;p.vy+=gravity;p.vx*=air;p.vy*=0.9985;if(hook.active){if(keys.w||keys.ArrowUp)hook.len=Math.max(60,hook.len-3.8);if(keys.s||keys.ArrowDown)hook.len=Math.min(820,hook.len+3.8);const dx=p.x-hook.x,dy=p.y-hook.y,d=Math.hypot(dx,dy)||.0001,nx=dx/d,ny=dy/d;if(d>hook.len){p.x=hook.x+nx*hook.len;p.y=hook.y+ny*hook.len;const radial=p.vx*nx+p.vy*ny;if(radial>0){p.vx-=radial*nx;p.vy-=radial*ny}}const tx=-ny,ty=nx,steer=((keys.d||keys.ArrowRight)?1:0)-((keys.a||keys.ArrowLeft)?1:0);p.vx+=tx*steer*.22;p.vy+=ty*steer*.22}p.x+=p.vx;p.y+=p.vy;p.rot=Math.atan2(p.vy,p.vx||.001);if(p.x<0){p.x=0;p.vx=0}if(p.x>worldW){p.x=worldW;p.vx=0}if(p.y>groundY+10)crash();score=Math.max(score,p.x/10);const sp=speed();if(sp>7.5&&!hook.active){score+=0.12*combo;comboTimer=Math.max(comboTimer,20)}if(comboTimer>0)comboTimer--;else combo=1;best=Math.max(best,Math.floor(score))}function drawBackground(){const g=x.createLinearGradient(0,0,0,H);g.addColorStop(0,"#d8e4ef");g.addColorStop(.55,"#d5dbe1");g.addColorStop(1,"#c3c8cd");x.fillStyle=g;x.fillRect(0,0,W,H);x.strokeStyle="rgba(0,0,0,0.045)";x.lineWidth=1;const grid=120,gx=-(cam.x%grid),gy=-(cam.y%grid);for(let i=gx;i<W;i+=grid){x.beginPath();x.moveTo(i,0);x.lineTo(i,H);x.stroke()}for(let i=gy;i<H;i+=grid){x.beginPath();x.moveTo(0,i);x.lineTo(W,i);x.stroke()}for(const s of skyline){const sx=s.x-cam.x*.35,sy=s.y-cam.y*.2;if(sx+s.w<0||sx>W)continue;x.fillStyle=%60rgba(70,80,90,${s.a})%60;x.fillRect(sx,sy,s.w,s.h)}}function drawBuildings(){for(const b of buildings){const sx=b.x-cam.x,sy=b.y-cam.y;if(sx+b.w<0||sx>W||sy+b.h<0||sy>H)continue;x.fillStyle="rgba(0,0,0,0.14)";x.fillRect(sx+8,sy+8,b.w,b.h);x.fillStyle=%60rgb(${b.shade},${b.shade},${b.shade})%60;x.fillRect(sx,sy,b.w,b.h);x.fillStyle="rgba(255,255,255,0.08)";x.fillRect(sx+6,sy+6,b.w-12,22);for(let yy=38;yy<b.h-14;yy+=24){for(let xx=14;xx<b.w-16;xx+=20){const on=(Math.sin(xx*0.13+yy*0.07+b.winSeed)>0.15);x.fillStyle=on?"rgba(255,220,120,0.15)":"rgba(255,255,255,0.04)";x.fillRect(sx+xx,sy+yy,9,12)}}x.strokeStyle="#2a2a2a";x.lineWidth=2;x.beginPath();x.moveTo(b.grappleX-cam.x,b.y-cam.y);x.lineTo(b.grappleX-cam.x,b.grappleY-cam.y);x.stroke();x.fillStyle="#ffd54a";x.beginPath();x.arc(b.grappleX-cam.x,b.grappleY-cam.y,6,0,Math.PI*2);x.fill();x.strokeStyle="rgba(255,213,74,0.35)";x.lineWidth=10;x.beginPath();x.arc(b.grappleX-cam.x,b.grappleY-cam.y,14,0,Math.PI*2);x.stroke()}x.fillStyle="#a9afb5";x.fillRect(-cam.x,groundY-cam.y,worldW,200)}function drawHook(){if(!hook.active)return;x.strokeStyle="rgba(20,20,20,0.9)";x.lineWidth=2.5;x.beginPath();x.moveTo(p.x-cam.x,p.y-cam.y);x.lineTo(hook.x-cam.x,hook.y-cam.y);x.stroke();x.fillStyle="#111";x.beginPath();x.arc(hook.x-cam.x,hook.y-cam.y,4,0,Math.PI*2);x.fill()}function drawPlayer(){const sx=p.x-cam.x,sy=p.y-cam.y;x.save();x.translate(sx,sy);x.rotate(p.rot);x.shadowColor="rgba(0,0,0,0.25)";x.shadowBlur=12;x.shadowOffsetY=5;x.fillStyle="#d32f2f";x.beginPath();x.arc(0,0,p.r,0,Math.PI*2);x.fill();x.fillStyle="#fff";x.fillRect(2,-3,8,6);x.restore()}function drawParticles(){for(const q of particles){x.fillStyle=%60rgba(255,120,0,${Math.max(0,q.life/50)})%60;x.beginPath();x.arc(q.x-cam.x,q.y-cam.y,q.size,0,Math.PI*2);x.fill()}}function drawHUD(){const sp=speed(),mom=Math.min(1,sp/10);x.fillStyle="rgba(255,255,255,0.84)";x.fillRect(16,16,310,126);x.strokeStyle="rgba(0,0,0,0.14)";x.strokeRect(16,16,310,126);x.fillStyle="#111";x.font="16px sans-serif";x.fillText("Distance: "+Math.floor(score),26,40);x.fillText("Best: "+Math.floor(best),26,62);x.fillText("Combo: x"+combo,26,84);x.fillText("Trick: "+Math.floor(trickScore),26,106);x.fillStyle="rgba(0,0,0,0.12)";x.fillRect(170,76,136,16);const mg=x.createLinearGradient(170,0,306,0);mg.addColorStop(0,"#7fd1ff");mg.addColorStop(1,"#1976d2");x.fillStyle=mg;x.fillRect(170,76,136*mom,16);x.strokeStyle="rgba(0,0,0,0.18)";x.strokeRect(170,76,136,16);x.fillStyle="#111";x.font="12px sans-serif";x.fillText("Momentum",170,70);if(comboTimer>0){x.fillStyle="rgba(255,170,0,0.18)";x.fillRect(170,98,136,10);x.fillStyle="#ff9800";x.fillRect(170,98,136*(comboTimer/180),10);x.strokeStyle="rgba(0,0,0,0.15)";x.strokeRect(170,98,136,10);x.fillStyle="#111";x.fillText("Combo time",170,120)}}function drawStartTip(){if(score>20||dead)return;x.fillStyle="rgba(255,255,255,0.88)";x.fillRect(W/2-220,H-84,440,50);x.strokeStyle="rgba(0,0,0,0.14)";x.strokeRect(W/2-220,H-84,440,50);x.fillStyle="#111";x.font="15px sans-serif";x.fillText("Hook yellow points, release with speed for tricks, avoid the floor.",W/2-195,H-53)}function drawDeath(){if(!dead)return;x.fillStyle="rgba(0,0,0,0.35)";x.fillRect(0,0,W,H);x.fillStyle="#fff";x.font="bold 34px sans-serif";x.fillText("YOU DIED",W/2-78,H/2-8);x.font="16px sans-serif";x.fillText("Press R to restart",W/2-62,H/2+22)}function draw(){drawBackground();drawBuildings();drawHook();drawPlayer();drawParticles();drawHUD();drawStartTip();drawDeath()}function loop(){updatePhysics();cam.x=lerp(cam.x,clamp(p.x-W*.35,0,Math.max(0,worldW-W)),.08);cam.y=lerp(cam.y,clamp(p.y-H*.45,0,Math.max(0,worldH-H)),.08);draw();requestAnimationFrame(loop)}function kd(e){keys[e.key]=true;if(e.key==="Escape")cleanup();if((e.key===" "||e.code==="Space"))releaseHook();if((e.key==="r"||e.key==="R")&&dead)restart()}function ku(e){keys[e.key]=false}function md(e){tryHook(e.clientX,e.clientY)}function mu(){releaseHook()}function cleanup(){removeEventListener("resize",resize);removeEventListener("keydown",kd);removeEventListener("keyup",ku);c.removeEventListener("mousedown",md);c.removeEventListener("mouseup",mu);c.remove();delete window.swingGame}addEventListener("keydown",kd);addEventListener("keyup",ku);c.addEventListener("mousedown",md);c.addEventListener("mouseup",mu);window.swingGame=cleanup;loop()})();
