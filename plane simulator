javascript:(()=>{  if(window.p){window.p();return;}  const c=document.createElement("canvas");  document.body.appendChild(c);  c.style.cssText="position:fixed;inset:0;z-index:99999;background:#dcdcdc;";  const x=c.getContext("2d");  let W=innerWidth,H=innerHeight,DPR=1;  function resize(){    W=innerWidth;    H=innerHeight;    DPR=Math.max(1,Math.min(2,window.devicePixelRatio||1));    c.width=W*DPR;    c.height=H*DPR;    c.style.width=W+"px";    c.style.height=H+"px";    x.setTransform(DPR,0,0,DPR,0,0);    x.imageSmoothingEnabled=true;  }  resize();  addEventListener("resize",resize);  const keys={};  let crashed=false;  let score=0;  let boomTime=0;  let checkpointsHit=0;  const worldSize=4200;  const plane={    x:worldSize/2,    y:worldSize/2,    angle:-Math.PI/2,    speed:3.2,    targetSpeed:3.2,    turnRate:0,    targetTurnRate:0,    bank:0,    radius:13  };  const trail=[];  const buildings=[];  const clouds=[];  for(let i=0;i<110;i++){    const bw=80+Math.random()*170;    const bh=80+Math.random()*170;    buildings.push({      x:Math.random()*(worldSize-bw),      y:Math.random()*(worldSize-bh),      w:bw,      h:bh    });  }  for(let i=0;i<35;i++){    clouds.push({      x:Math.random()*worldSize,      y:Math.random()*worldSize,      r:40+Math.random()*60    });  }  function clamp(v,a,b){return Math.max(a,Math.min(b,v));}  function dist(ax,ay,bx,by){const dx=ax-bx,dy=ay-by;return Math.hypot(dx,dy);}  function rectCircleCollide(cx,cy,cr,r){    const nx=Math.max(r.x,Math.min(cx,r.x+r.w));    const ny=Math.max(r.y,Math.min(cy,r.y+r.h));    const dx=cx-nx,dy=cy-ny;    return dx*dx+dy*dy<cr*cr;  }  function safeCheckpoint(){    for(let tries=0;tries<500;tries++){      const cp={        x:200+Math.random()*(worldSize-400),        y:200+Math.random()*(worldSize-400),        r:44      };      let ok=true;      for(const b of buildings){        const padding=90;        if(          cp.x+cp.r > b.x-padding &&          cp.x-cp.r < b.x+b.w+padding &&          cp.y+cp.r > b.y-padding &&          cp.y-cp.r < b.y+b.h+padding        ){          ok=false;          break;        }      }      if(ok && dist(cp.x,cp.y,plane.x,plane.y)>350) return cp;    }    return {x:300,y:300,r:44};  }  let checkpoint=safeCheckpoint();  function addTrail(){    trail.push({x:plane.x,y:plane.y,a:1});    if(trail.length>90) trail.shift();  }  function explode(){    crashed=true;    boomTime=0;  }  function update(){    const accel=0.025;    const speedLerp=0.025;    const turnResponse=0.06;    const bankResponse=0.08;    if(keys.w||keys.ArrowUp) plane.targetSpeed+=accel;    if(keys.s||keys.ArrowDown) plane.targetSpeed-=accel;    plane.targetSpeed=clamp(plane.targetSpeed,2.2,5.2);    plane.speed += (plane.targetSpeed-plane.speed)*speedLerp;    let steer=0;    if(keys.a||keys.ArrowLeft) steer=-1;    if(keys.d||keys.ArrowRight) steer=1;    const maxTurn=0.02;    plane.targetTurnRate=steer*maxTurn*(0.75+plane.speed*0.08);    plane.turnRate += (plane.targetTurnRate-plane.turnRate)*turnResponse;    plane.angle += plane.turnRate;    const vx=Math.cos(plane.angle)*plane.speed;    const vy=Math.sin(plane.angle)*plane.speed;    plane.x += vx;    plane.y += vy;    plane.x=clamp(plane.x,0,worldSize);    plane.y=clamp(plane.y,0,worldSize);    const targetBank=plane.turnRate*28;    plane.bank += (targetBank-plane.bank)*bankResponse;    addTrail();    for(let i=0;i<trail.length;i++) trail[i].a*=0.985;    for(const b of buildings){      if(rectCircleCollide(plane.x,plane.y,plane.radius,b)){        explode();        break;      }    }    if(!crashed && dist(plane.x,plane.y,checkpoint.x,checkpoint.y) < checkpoint.r + plane.radius){      checkpointsHit++;      score += 150;      checkpoint = safeCheckpoint();    }    score += plane.speed*0.05;  }  function drawGrid(camX,camY){    const grid=140;    x.strokeStyle="rgba(0,0,0,0.05)";    x.lineWidth=1;    const sx=-(camX%grid);    const sy=-(camY%grid);    for(let gx=sx;gx<W;gx+=grid){      x.beginPath();      x.moveTo(gx,0);      x.lineTo(gx,H);      x.stroke();    }    for(let gy=sy;gy<H;gy+=grid){      x.beginPath();      x.moveTo(0,gy);      x.lineTo(W,gy);      x.stroke();    }  }  function drawClouds(camX,camY){    for(const cl of clouds){      const sx=cl.x-camX;      const sy=cl.y-camY;      if(sx<-200||sy<-200||sx>W+200||sy>H+200) continue;      x.fillStyle="rgba(255,255,255,0.55)";      x.beginPath();      x.arc(sx-cl.r*0.4,sy,cl.r*0.65,0,Math.PI*2);      x.arc(sx,sy-cl.r*0.15,cl.r*0.8,0,Math.PI*2);      x.arc(sx+cl.r*0.45,sy,cl.r*0.6,0,Math.PI*2);      x.fill();    }  }  function drawBuildings(camX,camY){    for(const b of buildings){      const sx=b.x-camX;      const sy=b.y-camY;      if(sx+b.w<0||sy+b.h<0||sx>W||sy>H) continue;      x.fillStyle="rgba(0,0,0,0.12)";      x.fillRect(sx+7,sy+7,b.w,b.h);      x.fillStyle="#555";      x.fillRect(sx,sy,b.w,b.h);      x.fillStyle="#6a6a6a";      x.fillRect(sx+5,sy+5,b.w-10,Math.max(10,b.h*0.16));    }  }  function drawTrail(camX,camY){    for(let i=0;i<trail.length;i++){      const t=trail[i];      x.fillStyle=%60rgba(255,255,255,${t.a*0.18})%60;      x.beginPath();      x.arc(t.x-camX,t.y-camY,2.2,0,Math.PI*2);      x.fill();    }  }  function drawCheckpoint(camX,camY){    const sx=checkpoint.x-camX;    const sy=checkpoint.y-camY;    x.save();    x.strokeStyle="rgba(255,215,0,0.22)";    x.lineWidth=18;    x.beginPath();    x.arc(sx,sy,checkpoint.r+10,0,Math.PI*2);    x.stroke();    x.strokeStyle="#ffd54a";    x.lineWidth=8;    x.beginPath();    x.arc(sx,sy,checkpoint.r,0,Math.PI*2);    x.stroke();    x.strokeStyle="rgba(255,255,255,0.9)";    x.lineWidth=2;    x.beginPath();    x.arc(sx,sy,checkpoint.r-7,0,Math.PI*2);    x.stroke();    x.fillStyle="rgba(255,215,0,0.14)";    x.beginPath();    x.arc(sx,sy,checkpoint.r-12,0,Math.PI*2);    x.fill();    x.restore();  }  function drawPlane(){    x.save();    x.translate(W/2,H/2);    x.rotate(plane.angle);    x.transform(1,0,plane.bank*0.12,1,0,0);    x.shadowColor="rgba(0,0,0,0.24)";    x.shadowBlur=12;    x.shadowOffsetY=4;    x.fillStyle="#c62828";    x.beginPath();    x.moveTo(22,0);    x.lineTo(-10,-8);    x.lineTo(-3,0);    x.lineTo(-10,8);    x.closePath();    x.fill();    x.fillStyle="#9c1d1d";    x.fillRect(-5,-18,8,36);    x.fillStyle="#eeeeee";    x.beginPath();    x.arc(5,0,2.2,0,Math.PI*2);    x.fill();    x.restore();  }  function drawRadar(){    const size=155;    const rx=W-size-18;    const ry=18;    const scale=size/worldSize;    x.fillStyle="rgba(255,255,255,0.8)";    x.fillRect(rx,ry,size,size);    x.strokeStyle="rgba(0,0,0,0.2)";    x.strokeRect(rx,ry,size,size);    x.save();    x.beginPath();    x.rect(rx,ry,size,size);    x.clip();    x.fillStyle="#777";    for(const b of buildings){      x.fillRect(rx+b.x*scale,ry+b.y*scale,Math.max(2,b.w*scale),Math.max(2,b.h*scale));    }    x.strokeStyle="rgba(255,215,0,0.9)";    x.lineWidth=2;    x.beginPath();    x.arc(rx+checkpoint.x*scale,ry+checkpoint.y*scale,4,0,Math.PI*2);    x.stroke();    x.fillStyle="red";    x.beginPath();    x.arc(rx+plane.x*scale,ry+plane.y*scale,3,0,Math.PI*2);    x.fill();    x.strokeStyle="red";    x.beginPath();    x.moveTo(rx+plane.x*scale,ry+plane.y*scale);    x.lineTo(      rx+plane.x*scale+Math.cos(plane.angle)*12,      ry+plane.y*scale+Math.sin(plane.angle)*12    );    x.stroke();    x.restore();    x.fillStyle="#111";    x.font="12px sans-serif";    x.fillText("Radar",rx+10,ry+16);  }  function drawHUD(){    x.fillStyle="rgba(255,255,255,0.78)";    x.fillRect(14,14,220,96);    x.strokeStyle="rgba(0,0,0,0.14)";    x.strokeRect(14,14,220,96);    x.fillStyle="#111";    x.font="16px sans-serif";    x.fillText("Score: "+Math.floor(score),24,38);    x.fillText("Speed: "+plane.speed.toFixed(1),24,60);    x.fillText("Checkpoints: "+checkpointsHit,24,82);    x.fillText("WASD / Arrows",24,104);    drawRadar();  }  function drawExplosion(){    const t=boomTime;    const cx=W/2, cy=H/2;    for(let i=0;i<18;i++){      const a=(Math.PI*2/18)*i+t*0.05;      const r=18+t*2.8+(i%3)*8;      x.fillStyle=%60rgba(255,${160-Math.min(120,t*3)},0,${Math.max(0,0.8-t/40)})%60;      x.beginPath();      x.arc(cx+Math.cos(a)*r,cy+Math.sin(a)*r,10+t*0.35,0,Math.PI*2);      x.fill();    }    x.fillStyle="rgba(0,0,0,0.4)";    x.fillRect(0,0,W,H);    x.fillStyle="#fff";    x.font="bold 34px sans-serif";    x.fillText("CRASHED",W/2-78,H/2-8);    x.font="16px sans-serif";    x.fillText("Run the bookmark again or refresh",W/2-120,H/2+24);  }  function draw(){    const camX=plane.x-W/2;    const camY=plane.y-H/2;    x.fillStyle="#d9d9d9";    x.fillRect(0,0,W,H);    drawGrid(camX,camY);    drawClouds(camX,camY);    drawBuildings(camX,camY);    drawCheckpoint(camX,camY);    drawTrail(camX,camY);    drawPlane();    drawHUD();    if(crashed){      boomTime++;      drawExplosion();    }  }  function loop(){    if(!crashed) update();    draw();    requestAnimationFrame(loop);  }  function kd(e){    keys[e.key]=true;    if(e.key==="Escape") cleanup();  }  function ku(e){    keys[e.key]=false;  }  function cleanup(){    removeEventListener("keydown",kd);    removeEventListener("keyup",ku);    removeEventListener("resize",resize);    c.remove();    delete window.p;  }  addEventListener("keydown",kd);  addEventListener("keyup",ku);  window.p=cleanup;  loop();})();
